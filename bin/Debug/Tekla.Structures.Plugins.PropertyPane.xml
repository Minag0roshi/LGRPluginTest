        <member name="T:Tekla.Structures.Plugins.PropertyPane.PluginPropertyPaneFeatureBase">
             <summary>
             Plugin property pane feature base for showing plugin properties in property pane.
             </summary>
             <example>
             <code>
             
             using System.Collections.Generic;
             using Tekla.Structures.Plugins.PropertyPaneFeature;
             
             public class ExamplePluginPanelFeature : PluginPropertyPaneFeatureBase
             {
                 public ExamplePluginPanelFeature()
                 {
                     this.InitializeFeature("TeklaWPFExamplePlugin", "TeklaWPFExamplePlugin", string.Empty);
                     this.BuildTemplate();
                 }
            
                 private void BuildTemplate()
                 {
                     // Add properties group
                     this.AddPropertyGroup("Properties", "Generic properties", true);
                     
                     // Add properties for proprerties group
                     this.AddDualProperty("Properties", Dual.Numbering, "prefix", "startno", "albl_Numbering", "albl_Numbering");
                     this.AddCatalogProperty("Properties", Catalog.Profile, "profile", "", "", "Profile", "Profile");
                     this.AddSingleProperty("Properties", Single.String, "name", "Name", "Name");
                     this.AddSingleProperty("Properties", Single.Distance, "offset", "Offset Z", "Offset Z");
                     var values = new List&lt;string&gt;() { "Yes", "No", "Maybe" };
                     this.AddDropDownProperty("Properties", values, "possiblity", "Possibility", "Possibility");
                     
                      // Add bolts group and properties
                     this.AddPropertyGroup("Bolts", "Bolt groups", false);
                     this.AddCatalogProperty("Bolts", Catalog.Bolt, "grade", "size", "", "Bolt", "Bolt");
                     this.AddCatalogProperty("Bolts", Catalog.Bolt, "grade2", "size2", "", "Bolt2", "Bolt2");
                     
                      // Add rebars group and properties
                     this.AddPropertyGroup("Rebars", "Reinforcement", false);
                     this.AddCatalogProperty("Rebars", Catalog.RebarGrade, "rebargrade", "rebarsize", "bendradius", "Rebar", "Rebar");
                     this.AddCatalogProperty("Rebars", Catalog.RebarGrade, "rebargrade2", "rebarsize2", "bendradius2", "Rebar2", "Rebar2");
                 }
             }
             </code>
             </example>
        </member>
